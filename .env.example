# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=assetdb
POSTGRES_USER=assetuser
# تم التعديل: ضع كلمة مرور قوية هنا
POSTGRES_PASSWORD=my_super_secret_password

# ── Connection pool tuning ────────────────────────────────────────────────────
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=300

# ── OpenAI ────────────────────────────────────────────────────────────────────
# تم التعديل: ضع مفتاحك الفعلي هنا
OPENAI_API_KEY=sk-proj-YourActualOpenAIApiKeyHere...
LLM_MODEL=gpt-4o

# ── Agent tuning ──────────────────────────────────────────────────────────────
AGENT_MAX_ITERATIONS=10
AGENT_TIMEOUT_SECONDS=120

# ── FastAPI / Uvicorn ────────────────────────────────────────────────────────
APP_PORT=8000
ALLOWED_HOSTS=*

# ── AI layer — self-referential API base URL ──────────────────────────────────
# تم التعديل: تحويله إلى http://app:8000 لأننا نشغل المشروع عبر docker-compose
ASM_API_BASE_URL=http://app:8000

# ── Evaluation harness ────────────────────────────────────────────────────────
EVAL_ORG_ID=eval-org-harness-001